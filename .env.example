# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Paystack Configuration
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_key_here

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# WhatsApp Cloud API (Optional for Professional Integration)
VITE_WHATSAPP_ACCESS_TOKEN=your_token_here
VITE_WHATSAPP_PHONE_NUMBER_ID=your_id_here
VITE_WHATSAPP_BUSINESS_ACCOUNT_ID=your_biz_id_here
VITE_WHATSAPP_RECIPIENT_NUMBER=your_recipient_phone_here
